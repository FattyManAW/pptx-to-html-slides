<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Presentation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700|Playfair+Display:wght@600;700;800;900|Noto+Sans+SC:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all';this.onload=null">
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700|Playfair+Display:wght@600;700;800;900|Noto+Sans+SC:wght@300;400;500;600;700&display=swap"></noscript>
<meta name="description" content="IMPACTs 双碳数字化管理系统 — 基于用友BIP平台的碳管理一体化解决方案">
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🌱</text></svg>">
<style>
/*===============================================================
  Design System — 润思IMPACTS v3.1 — Christina Canonical + Teal System
  Tokens: 36 colors | 6 timing | 0 font weights
  ================================================================*/

/*============================== [00] DESIGN TOKENS — Colors: ink50, ink100, ink200, ink300, ink400, ink500... | Typography: display, heading, body, mono */
:root {
  --ink-50:  #f8fafc;
  --ink-100: #f1f5f9;
  --ink-200: #e2e8f0;
  --ink-300: #cbd5e1;
  --ink-400: #94a3b8;
  --ink-500: #64748b;
  --ink-600: #475569;
  --ink-700: #334155;
  --ink-800: #1e293b;
  --ink-900: #0f172a;
  --ink-950: #06080d;
  --accent:  #14b8a6;
  --accent-mid: #2dd4bf;
  --c-t1: #f0f4f8;
  --c-t2: #94a3b8;
  --c-t3: #64748b;
  --c-t4: #3b5068;
  --c-error:   #ef4444;
  --c-success: #22c55e;
  --c-warning: #f59e0b;
  --c-info:    #3b82f6;
  --surface: rgba(255,255,255,.04);
  --surface-h: rgba(255,255,255,.07);
  --border:  rgba(255,255,255,.08);
  --border-a:rgba(20,184,166,.12);
  --blur:     blur(24px);
  --blur-card:  blur(10px);
  --blur-sheet: blur(20px);
  --blur-modal: blur(30px);
  --blur-nav:   blur(20px);
  --blur-8:  blur(8px);
  --blur-12: blur(12px);
  --blur-24: blur(24px);
  --blur-32: blur(32px);
  --shadow:  0 8px 40px rgba(0,0,0,.35);
  --ease:    cubic-bezier(0.4, 0, 0.2, 1);
  --t-fast:  150ms;
  --t-mid:   300ms;
  --t-slow:  400ms;
  --c-bg:    #06080d;
  --c-bg2:   #0f172a;
  --c-bg3:   #1e293b;
  --c-surface:  rgba(255,255,255,.04);
  --c-surface2: rgba(255,255,255,.07);
  --c-glass:    rgba(6,8,13,.65);
  --c-border:   rgba(255,255,255,.08);
  --c-teal:     #14b8a6;
  --c-teal-dim: rgba(20,184,166,.12);
  --c-teal-glow: rgba(20,184,166,.25);
  --c-teal-hot: #2dd4bf;
  --c-t1:  #f0f4f8;
  --c-t2:  #94a3b8;
  --c-t3:  #64748b;
  --c-t4:  #3b5068;
  --s1: 0.5rem; --s2: 1rem; --s3: 1.5rem;
  --s4: 2rem;   --s5: 2.5rem; --s6: 3rem;
  --s7: 4rem;   --s8: 5rem;  --s9: 6rem;
  --s10: 8rem;
  --display: 'Playfair Display',serif;
  --heading: 'Playfair Display','Noto Serif SC',serif;
}

/*================================= [01] RESET ==================================*/
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden;-webkit-font-smoothing:antialiased;touch-action:pan-y}
body{font-family:'Inter','Noto Sans SC',sans-serif;background:var(--c-bg);color:var(--c-t2);line-height:1.65}

/*=============================== [02] SLIDE ENGINE ===============================*/
.slides-container{position:relative;width:100vw;height:100vh;overflow:hidden;background:var(--c-bg)}
.slide{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0;visibility:hidden;animation:springIn var(--t-slow) var(--ease) forwards;transform:translateY(12px);padding:2rem;will-change:opacity,transform}
.slide.active{opacity:1;visibility:visible;transform:translateY(0);z-index:10}
.slide.prev{opacity:0;transform:translateY(-12px)}
.slide.active [data-stagger="0"]{transition-delay:0ms}
.slide.active [data-stagger="80"]{transition-delay:80ms}
.slide.active [data-stagger="160"]{transition-delay:160ms}
.slide.active [data-stagger="240"]{transition-delay:240ms}
.slide.active [data-stagger="320"]{transition-delay:320ms}

@keyframes springIn {
  0%   { opacity:0; transform:translateY(12px) scale(.97); }
  60%  { opacity:1; transform:translateY(-2px) scale(1.01); }
  80%  { transform:translateY(1px) scale(.995); }
  100% { opacity:1; transform:translateY(0) scale(1); }
}
@keyframes slideUp {
  0%   { opacity:0; transform:translateY(24px); }
  100% { opacity:1; transform:translateY(0); }
}
@keyframes slideFromRight {
  0%   { opacity:0; transform:translateX(40px); }
  100% { opacity:1; transform:translateX(0); }
}
@keyframes slideExit {
  0%   { opacity:1; transform:translateY(0); }
  100% { opacity:0; transform:translateY(-16px); }
}
@keyframes shimmer {
  0%,100% { background-position:0% 50%; }
  50%     { background-position:100% 50%; }
}
.slide *{opacity:0;transform:translateY(8px);transition:opacity var(--t-mid) var(--ease),transform var(--t-mid) var(--ease)}
.slide.active *{opacity:1;transform:translateY(0)}
.slide-inner{width:100%;max-width:1100px;padding:2rem 1.5rem}

/*================================= [03] PROGRESS ==================================*/
.progress-bar{position:fixed;top:0;left:0;height:1.5px;background:linear-gradient(90deg,var(--c-teal),var(--c-teal-hot));transition:width var(--t-mid) var(--ease);z-index:301}
.progress-track{position:fixed;bottom:0;left:0;right:0;height:1px;background:rgba(255,255,255,.05);z-index:301}

/*=============================== [04] NAVIGATION ================================*/
.nav-bar{position:fixed;bottom:0;left:0;right:0;z-index:300;display:flex;align-items:center;justify-content:center;gap:1rem;padding:1rem 2rem;background:linear-gradient(transparent,var(--c-glass));backdrop-filter:blur(20px);border-top:1px solid var(--border)}
.nav-btn{width:40px;height:40px;border-radius:50%;border:1px solid var(--border);background:var(--surface);color:var(--c-t2);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all var(--t-fast);font-size:1rem;user-select:none}
.nav-btn:hover{filter:brightness(1.15);background:var(--c-surface2);border-color:var(--c-teal-dim)}
.nav-btn:disabled{opacity:.28;cursor:not-allowed;filter:grayscale(50%)}
.nav-counter{font-size:.75rem;color:var(--c-t3);font-weight:500;letter-spacing:.08em;min-width:3rem;text-align:center}
.nav-counter .current{color:var(--c-t1);font-weight:600}
.slide-num{font-size:.65rem;font-weight:600;color:var(--accent);letter-spacing:.1em;opacity:.5}
.fs-btn{width:32px;height:32px;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--c-t3);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all var(--t-fast);font-size:.75rem;margin-left:auto}

/*============================= [05] SECTION BREAK ==============================*/
.section-break{width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;background:var(--c-bg)}
.section-num{font-family:'Playfair Display',serif;font-size:6rem;font-weight:900;color:var(--c-teal);opacity:.12;line-height:1}
.section-title{font-family:'Playfair Display','Noto Serif SC',serif;font-size:clamp(1.6rem,4vw,2.5rem);font-weight:700;color:var(--c-t1);letter-spacing:-.02em}
.section-sub{font-size:1rem;color:var(--c-t3);margin-top:.8rem;font-weight:300}

/*============================= [06] SLIDE CONTENT ==============================*/
.slide-header{display:flex;align-items:baseline;gap:.8rem;margin-bottom:1.5rem}
.slide-num{font-size:.65rem;font-weight:600;color:var(--accent);letter-spacing:.1em;opacity:.5}
.slide-title{font-family:'Playfair Display','Noto Serif SC',serif;font-size:clamp(1.2rem,2.5vw,1.7rem);font-weight:700;color:var(--c-t1);position:relative;padding-bottom:.4rem}
.slide-title::after{content:'';position:absolute;bottom:-1px;left:0;width:36px;height:2px;background:linear-gradient(90deg,var(--c-teal),transparent)}
.slide-sub{font-size:.9rem;color:var(--c-t3);font-weight:300;letter-spacing:.05em;margin-bottom:1.5rem;padding-left:3.5rem}
.slide-headline{font-family:'Playfair Display',serif;font-size:clamp(1.4rem,3vw,2rem);font-weight:700;color:var(--c-t1);margin-bottom:.8rem}
.slide-body{font-size:clamp(.8rem,1.2vw,.92rem);color:var(--c-t2);line-height:1.75;max-width:80ch;margin-bottom:1.2rem}
.slide-body strong{color:var(--c-t1);font-weight:600}

/*=================================== [07] CARDS ===================================*/
.item-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:1rem 1.1rem;transition:all var(--t-fast)}
.item-card:hover{filter:brightness(1.05);background:var(--c-surface2);border-color:var(--c-teal-dim)}
.item-card:active{transform:scale(.97);filter:brightness(.95);transition-duration:50ms}

/*=================================== [08] TWO-COL ===================================*/
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start;width:100%}
.two-col>*{min-width:0}

/*==================================== [09] IMAGES ====================================*/
.slide-img{width:100%;height:auto;max-height:55vh;object-fit:contain;border-radius:8px}

/*=================================== [10] THANK YOU ===================================*/
.thankyou{text-align:center}
.thankyou h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:800;color:var(--c-t1);margin-bottom:.5rem}
.thankyou p{color:var(--c-t3);font-weight:300;font-size:1.1rem}
.thankyou .logo{font-size:.85rem;color:var(--c-t4);margin-top:2rem;letter-spacing:.15em;text-transform:uppercase}

/*==================================== [11] COVER =====================================*/
.cover{width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;position:relative;overflow:hidden}
.cover-bg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 40%,rgba(99,102,241,.12),transparent 70%)}
.cover-title{font-family:'Playfair Display',serif;font-size:clamp(2rem,5.5vw,4rem);font-weight:900;color:var(--c-t1);text-align:center;line-height:1.1;position:relative;z-index:1;background:linear-gradient(135deg,var(--c-t1) 0%,var(--c-teal) 50%,var(--c-t1) 100%);background-size:200% 100%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:shimmer 3s ease-in-out infinite}
.cover-title em{font-style:normal;background:linear-gradient(135deg,var(--c-teal),var(--c-teal-hot));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.cover-sub{font-size:clamp(.85rem,1.5vw,1.1rem);color:var(--c-t3);margin-top:1.2rem;text-align:center;max-width:600px;position:relative;z-index:1;font-weight:300}
.cover-meta{margin-top:2.5rem;display:flex;gap:2rem;position:relative;z-index:1}
.cover-meta span{font-size:.75rem;color:var(--c-t4);letter-spacing:.12em;text-transform:uppercase}

/*=============================== [12] RESPONSIVE — 1024/768/480 ===============================*/
@media(max-width:1024px){
  .two-col{grid-template-columns:1fr;gap:1.5rem}
  .slide-inner{padding:1.5rem 1rem}
}
@media(max-width:768px){
  .slide{padding:1rem}
  .slide-inner{padding:1rem .5rem}
  .slide-title{font-size:1.1rem}
  .slide-body{font-size:.82rem}
  .item-card{padding:.8rem}
  .nav-bar{padding:.5rem 1rem;gap:.5rem}
}
@media(max-width:480px){
  .cover-title{font-size:1.8rem}
  .section-num{font-size:4rem}
  .cover-meta{flex-direction:column;gap:.8rem;align-items:center}
}

/*================================= [13] UTILITIES ==================================*/
:focus-visible{outline:2px solid var(--c-teal);outline-offset:2px}
*:focus:not(:focus-visible){outline:none}
.tag{display:inline-block;padding:.15rem .6rem;border-radius:999px;font-size:.7rem;font-weight:600;letter-spacing:.04em}
.tag-teal{background:var(--c-teal-dim);color:var(--c-teal)}
.tag-warn{background:rgba(245,158,11,.12);color:var(--c-warning)}
.tag-err{background:rgba(239,68,68,.12);color:var(--c-error)}
.tag-ok{background:rgba(34,197,94,.12);color:var(--c-success)}
.kv{display:flex;gap:.5rem;align-items:baseline;flex-wrap:wrap;margin:.25rem 0}
.kv k{font-weight:600;color:var(--c-t1);min-width:5rem}
.kv v{color:var(--c-t2);font-weight:300}
.bullets{list-style:none;padding:0;margin:0}
.bullets li{position:relative;padding-left:1.4rem;margin-bottom:.45rem;color:var(--c-t2);font-size:.88rem;line-height:1.7}
.bullets li::before{content:'→';position:absolute;left:0;color:var(--c-teal);font-weight:700}
.steps{display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;margin:.5rem 0}
.step{display:flex;align-items:center;gap:.4rem;padding:.3rem .8rem;border-radius:8px;background:var(--surface);border:1px solid var(--border);font-size:.8rem;color:var(--c-t2)}
.step-arrow{color:var(--c-teal);font-weight:700}
.two-up{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
@media(max-width:768px){.two-up{grid-template-columns:1fr}}
.center{text-align:center}
.mt1{margin-top:var(--s1)}.mt2{margin-top:var(--s2)}.mt3{margin-top:var(--s3)}
.mb1{margin-bottom:var(--s1)}.mb2{margin-bottom:var(--s2)}.mb3{margin-bottom:var(--s3)}

</style>
</head>
<body>
<div class="slides-container" id="slides" aria-label="IMPACTs 双碳数字化管理系统 — 投影片展示">
<div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳数字化管理系统</h2><p>助力企业实现双碳目标</p><p>大连润思科技制造行业及智能制造解决方案商</p><p>基于用友BIP平台的碳管理一体化系统</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">双碳政策背景与行业趋势</h2><p>01</p><p>企业双碳管理现状与挑战</p><p>02</p><p>IMPACTs 双碳管理解决方案</p><p>03</p><p>IMPACTs 双碳管理客户案例</p><p>04</p><img class="slide-img" src="images/slide2_图片_15_f29c5461.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide2_图片_21_311740dd.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide2_图片_22_311740dd.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide2_图片_23_f29c5461.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">双碳政策背景与行业趋势</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">政策与市场双重驱动—碳管理的挑战与机遇</h2><p>全球政策加速碳管理刚性化</p><p>欧盟CBAM碳关税2027年全面实施，首批覆盖钢铁/铝/电力等行业；欧盟CSRD&ESRS：强制要求披露范围1-3碳排放，覆盖在欧经营的中国企业，2025年起需提供碳足迹认证，2027年实施数字电池护照，国际碳壁垒形成倒逼企业建立全供应链碳数据体系，未达标者面临关税惩罚或退市风险。</p><p>2030碳达峰、2060碳中和国家战略</p><p>碳市场扩容</p><p>全国碳市场逐步纳入建材、有色等八大行业。覆盖45亿吨排放量，国家发改委等五部门要求2025年建立50+重点产品碳足迹标准，碳标识认证制度基本成型。</p><p>地方强化监管及建设试点标杆</p><p>碳核查违规最高罚款200万元+配额核减50%-100%，2024年查处ESG数据造假案件87起，单案平均罚款超500万元。常州对动力电池/光伏企业碳足迹认证最高补贴5万元，零碳工厂奖励100万元。</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">政策与市场双重驱动—碳管理的挑战与机遇</h2><p>在ESG框架下，碳管理已从合规成本转变为核心竞争力，政策、资本与技术三重驱动将加速行业洗牌，数字化与透明化成为企业突围关键。</p><p>ESG投资倒逼碳数据透明化</p><p>资本要求  全球ESG资管规模超40万亿美元，MSCI碳指标权重达15%，香港联交所将范围3碳排放列入强制披露</p><p>供应链压力  64%消费者将可持续性列为采购前三因素，苹果、沃尔玛等巨头等巨头要求供应商披露碳数据且必须实现供应商2030年实现碳中和，未达标者订单削减比例达40%。目前仅9%企业能完整计算范围3排放，错误率高达30-40%</p><p>政策红利  中国多地推出“碳挂钩”金融工具：绿色信贷、碳中和债券依赖准确碳盘查数据碳足迹挂钩贷款利率直接关联企业减排绩效，ESG表现优异企业获低息贷款+税收优惠</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">企业碳中和实施步骤</h2><p>1</p><p>2</p><p>3</p><p>4</p><p>5</p><p>制定碳目标</p><p>评价碳绩效</p><p>摸清碳家底</p><p>执行碳减排</p><p>实现碳中和</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">品牌价值升级</h2><p>碳盘查帮助企业精准掌握碳排放数据，满足碳市场交易、碳税缴纳等政策要求。随着"双碳"政策深化，重点行业均需参与碳排放管理。通过系统化盘查，企业可规避数据不清导致的合规风险，确保生产经营合法有序</p><p>企业做碳盘查的必要性</p><p>有效提升品牌绿色形象</p><p>增强市场竞争力</p><p>合规经营保障</p><p>碳盘查帮助企业精准掌握碳排放数据，满足碳市场交易、碳税缴纳等政策要求。随着"双碳"政策深化，重点行业均需参与碳排放管理。通过系统化盘查，企业可规避数据不清导致的合规风险，确保生产经营合法有序</p><p>降本增效利器</p><p>碳盘查过程中，企业能够发现高耗能、高排放的环节和设备，通过技术改造、工艺优化等措施，在实现减排目标的同时，降低能源消耗和生产成本</p><p>国际通行证</p><p>面对欧盟CBAM等绿色贸易壁垒，碳盘查数据是产品出口的必要凭证，系统化的碳排放管理可确保企业符合国际碳足迹标准，避免因碳数据缺失损失海外订单，维护国际市场竞争力</p><p>融资新优势</p><p>金融机构将碳管理纳入信贷评估体系，碳盘查完善的企业可获得利率优惠。2023年绿色信贷数据显示，碳数据透明的企业平均融资成本降低1.2个百分点，绿色债券发行成功率提升40%</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">企业双碳管理现状与挑战</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">企业碳管理痛点分析</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">企业碳管理痛点分析</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案</h2><p>IMPACTs双碳智能管理系统基于物联网实时监测、AI智能算法等核心技术，打造覆盖数据采集-智能核算-清册报告-碳资产管理全流程的一站式解决方案</p><p>系统严格遵循ISO 14064、GHG Protocol等国际标准，全面覆盖范围1-3碳排放管理场景，满足集团型企业及供应链协同需求</p><p>作为用友ISV生态认证产品，深度对接用友ERP、APS、MES、SCM等核心业务系统，实现碳排放数据的自动化采集、智能化分析和全链路闭环管理，助力企业高效达成双碳目标，提升碳管理效能</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-综合解决方案体系</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-主要适用行业</h2><p>重工业领域</p><p>电力能源行业</p><p>交通运输业</p><p>建筑房地产</p><p>电子信息产业</p><p>零售服务业</p><p>农林牧渔业</p><p>医药化工业</p><p>园区及公共机构</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><img class="slide-img" src="images/slide16_圖片_4_26c41198.jpeg" alt="" loading="lazy" decoding="async"><h2 class="slide-headline">IMPACTs 双碳管理解决方案</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-核心功能</h2><p>多源数据采集与整合</p><p>支持来自不同来源的数据收集和分析，包括能源消耗、工业过程排放和废弃物处理等。</p><p>精准碳排放核算</p><p>依据国际标准，对企业所有业务活动的碳排放进行核算</p><p>深度数据分析与洞察​帮助企业识别减排机会，制定具体的减排措施。</p><p>合规报告生成与管理生成符合国际标准的碳排放报告，并协助企业获得相关认证</p><img class="slide-img" src="images/slide17_圖片_9_9da01cd5.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-核心功能</h2><p>数据标准化处理</p><p>系统自动对采集的数据进行格式转换、编码统一等标准化处理，确保不同来源的数据能够规范存储与分析。无论是结构化数据还是半结构化数据，都能快速适配系统要求，为后续的核算与分析奠定基础</p><p>多样化数据采集方式</p><p>支持手动录入、文件导入（ Excel）、API 接口对接等多种方式，方便企业从 ERP、能源管理系统等多数据源获取数据，减少人工录入的工作量与误差​</p><p>数据完整性校验</p><p>具备数据完整性校验机制，实时检查数据是否存在缺失值、重复值等问题</p><p>系統截圖</p><p>多源数据采集与整合​</p><p>系統截圖</p><p>01</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-核心功能</h2><p>动态因子库</p><p>集成IPCC国际指南、PAS 2050、国家发改委行业核算指南及企业历史数据，实现排放因子版本化管理与自动更新</p><p>权威核算模型内置</p><p>内置符合国际国内标准（如 ISO 14064、GHG protocol等）的碳排放核算模型，针对不同行业、不同排放源（范围一、二、三）提供对应的核算公式</p><p>精准碳排放核算</p><p>02</p><p>系統截圖</p><img class="slide-img" src="images/slide19_图片_3_15286e7b.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-核心功能</h2><p>灵活参数配置</p><p>支持企业根据自身实际情况自定义核算参数，如燃料的碳排放因子、生产工艺系数等。对于一些特殊行业或采用新技术的企业，可以灵活调整参数，使核算结果更贴合实际排放情况</p><p>精准碳排放核算</p><p>02</p><p>系統截圖</p><p>系統截圖</p><img class="slide-img" src="images/slide20_图片_4_325af613.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-核心功能</h2><p>精准碳排放核算</p><p>02</p><p>自动合规核算</p><p>企业只需输入基础数据，系统就能自动计算出准确的碳排放量，确保核算结果符合规范要求</p><p>多维度核算分析</p><p>可按照时间维度（日、月、季度、年）、空间维度（不同厂区、车间）、排放源维度等进行碳排放核算与分析。帮助企业清晰了解不同阶段、不同区域、不同排放源的碳排放分布情况，精准定位高排放环节</p><p>系統截圖</p><p>系統截圖</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-核心功能</h2><p>精准碳排放核算 – 系统展示</p><p>02</p><p>自动合规核算</p><p>企业只需输入基础数据，系统就能自动计算出准确的碳排放量，确保核算结果符合规范要求</p><p>系統截圖</p><p>系統截圖</p><img class="slide-img" src="images/slide22_图片_3_8f029ddb.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-核心功能</h2><p>智能化决策管理</p><p>企业管理者无需复杂的数据分析知识，就能快速掌握企业碳排放整体情况与变化趋势</p><p>可视化数据展示</p><p>通过系统内置图表（柱状图、折线图、饼图等）、仪表盘等形式，直观展示碳排放趋势、排放结构占比等关键数据</p><p>系統截圖</p><p>深度数据分析与洞察​</p><p>系統截圖</p><p>03</p><img class="slide-img" src="images/slide23_图片_3_47932b96.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide23_图片_5_55b82c95.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-核心功能</h2><p>支持一键导出</p><p>支持一键导出Word 格式，大大提高报告编制效率</p><p>自动化报告生成</p><p>根据核算结果，系统自动生成符合监管要求的碳盘查报告，报告内容涵盖企业基本信息、核算边界、排放源分析、碳排放量汇总等关键内容</p><p>系統截圖</p><p>合规报告生成与管理</p><p>04</p><img class="slide-img" src="images/slide24_图片_5_226934cc.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-产品优势</h2><p>行业覆盖广</p><p>电力、钢铁、化工、制造、物流等多大行业定制化模型</p><p>数据穿透深</p><p>支持范围一（直接排放）、范围二（间接排放）、范围三（供应链）全层级核算</p><p>生态兼容性</p><p>与用友ISV深度集成无缝对接，实现数据互通</p><p>合规与认证保障</p><p>严格遵循全球主流碳核算标准，确保企业合规无忧</p><p>国际标准</p><p>ISO 14064-1/14067双认证， GHG Protocol支持欧盟CSRD、美国SEC等12项国际披露</p><p>国内适配</p><p>内置最新国家核算指南，满足跨国经营合规需求，降低90%政策违规风险</p><p>技术架构优势</p><p>全栈国产化底座，基于用友ISV平台，采用“简强微服务架构"，支持公有云/私有云混合部署</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-服务优势</h2><p>专业团队与经验</p><p>拥有专业的碳盘查团队，具备丰富的行业经验和专业知识，能够为客户提供高质量、个性化的碳盘查服务</p><p>一站式解决方案</p><p>提供从数据收集、核算、分析到报告、认证的一站式碳盘查服务，满足企业不同阶段的碳管理需求，节省企业的时间和精力</p><p>定制化服务</p><p>根据企业的规模、行业特点和具体需求，量身定制碳盘查方案，确保方案的针对性和有效性</p><p>持续更新与支持</p><p>紧跟国际国内碳排放政策和标准的变化，及时更新碳盘查方法和工具，为客户提供持续的技术支持和服务保障</p><p>数据安全与保密</p><p>采用先进的数据加密技术和严格的数据管理流程，确保企业碳排放数据的安全和保密，让企业放心使用</p><p>客户成功案例</p><p>拥有众多成功的客户案例，积累了丰富的实践经验，能够为客户提供可借鉴的成功经验和最佳实践</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理解决方案-服务优势</h2><p>与用友系统无缝集成</p><p>作为用友ISV合作伙伴，IMPACTs 碳盘查能够与用友的ERP、APS、财务管理、供应链管理等系统无缝集成，实现数据的自动流转和共享，减少数据重复录入，提高工作效率</p><p>强大的数据处理能力</p><p>借助用友强大的数据处理平台，能够快速处理海量的碳排放数据，确保数据的准确性和及时性，为企业提供实时的碳排放监控和分析</p><p>灵活的系统扩展性</p><p>基于用友的开放平台， IMPACTs 碳盘查具有良好的系统扩展性，能够根据企业的发展需求，灵活扩展功能模块，满足企业不断变化的碳管理需求</p><p>智能化分析与决策支持</p><p>利用用友的智能分析工具，对碳排放数据进行深度挖掘和分析，为企业提供智能化的减排策略和决策支持，帮助企业实现碳排放的精细化管理</p><p>稳定可靠的技术保障</p><p>依托用友成熟的技术架构和稳定的技术支持体系，确保碳盘查系统的稳定运行，降低企业的技术风险</p><p>行业领先的解决方案</p><p>结合用友在企业管理软件领域的领先地位，我们的碳盘查能够为企业提供行业领先的碳管理解决方案，助力企业在市场竞争中脱颖而出</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">IMPACTs 双碳管理客户案例</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">合作伙伴</h2><img class="slide-img" src="images/slide29_Picture_2_324227a4.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide29_Picture_4_de3ccd43.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide29_圖片_71_bd12a8f5.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide29_圖片_72_d2fe6db7.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide29_Picture_16_f360c655.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide29_Picture_20_21511b88.gif" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide29_圖片_75_75649a92.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">部分行业客户案例——某金属制品有限公司</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">部分行业客户案例——某金属制品有限公司</h2><p>实施成效</p><p>战略价值</p><p>获得沃尔沃"绿色供应商"认证</p><p>通过欧盟CBAM首年核查</p><p>入围某新能源车企核心供应商名单</p><p>年减排二氧化碳8986吨</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">部分行业客户案例——某金属制品有限公司</h2><p>资料云</p><p>PLC/Sensor/SMB</p><p>搜集数据</p><p>云端生产能源</p><p>碳排实时监控</p><p>生产状况</p><p>实时追踪</p><p>设备碳排监控系统</p><p>(i-MCMS)</p><p>分析</p><p>分析</p><p>设备升级，提升生产力</p><p>软件系统建置</p><p>硬设备基础升级</p><p>1</p><img class="slide-img" src="images/slide32_圖片_11_18242df6.jpeg" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide32_圖片_12_3c28a276.jpeg" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide32_圖片_13_d8519b72.jpeg" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide32_圖片_6_6509d5cc.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide32_Picture_2_c939f157.jpeg" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide32_Picture_4_d584d73e.jpeg" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide32_图片_11_84c5dd15.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide32_图片_13_7be76856.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">部分行业客户案例——某胶膜有限公司</h2></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">部分行业客户案例——某胶膜有限公司</h2><p>实施成效</p><p>战略价值</p><p>成为行业内碳足迹认证的胶膜企业</p><p>获得国际客户20%的绿色订单溢价</p><p>入选省级"智能工厂"示范项目</p><p>预计2.5年收回改造成本</p></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">部分行业客户案例——某胶膜有限公司</h2><p>资料云</p><p>PLC/Sensor/SMB</p><p>搜集数据</p><p>云端生产能源</p><p>碳排实时监控</p><p>生产状况</p><p>实时追踪</p><p>设备碳排监控系统</p><p>(i-MCMS)</p><p>分析</p><p>分析</p><p>回传</p><p>设备升级，提升生产力</p><p>监控各机台的用电量</p><p>软件系统建置</p><p>硬设备基础升级</p><img class="slide-img" src="images/slide35_Picture_2_f8662c80.jpeg" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide35_Picture_4_15ce62e5.jpeg" alt="" loading="lazy" decoding="async"><p>UV光固化设备</p><p>洁净室</p><p>：採变频空调系统</p><p>1</p><img class="slide-img" src="images/slide35_图片_7_4eeb8f8a.png" alt="" loading="lazy" decoding="async"><img class="slide-img" src="images/slide35_图片_9_81b44b60.png" alt="" loading="lazy" decoding="async"></div></div><div class="slide" data-stagger="0"><div class="slide-inner"><h2 class="slide-headline">Thank you！</h2></div></div>
</div>
<div class="progress-track"><div class="progress-bar" id="progressBar"></div></div>
<nav class="nav-bar">
  <button class="nav-btn" id="prevBtn" disabled>‹</button>
  <span class="nav-counter"><span class="current" id="curNum">1</span> / 36</span>
  <button class="nav-btn" id="nextBtn">›</button>
  <span id="cnt" style="position:fixed;top:.8rem;right:1rem;font-size:.65rem;color:var(--c-t4);font-weight:500;z-index:301"></span>
  <button class="fs-btn" id="fsBtn" title="Fullscreen">⛶</button>
</nav>
<script>
(function(){
  const slides=document.querySelectorAll('.slide,.section-break');
  const bar=document.getElementById('progressBar');
  const cur=document.getElementById('curNum');
  const prevBtn=document.getElementById('prevBtn');
  const nextBtn=document.getElementById('nextBtn');
  let current=0,total=slides.length;
  const debounce={};
  const WHEEL_DEBOUNCE=120;

  function go(n){
    if(n<0||n>=total)return;
    const prev=slides[current];prev.classList.remove('active');prev.classList.add('prev');
    current=n;
    slides[current].classList.add('active');slides[current].classList.remove('prev');
    bar.style.width=((current+1)/total*100)+'%';
    cur.textContent=current+1;document.getElementById('cnt').textContent=current+1+'/'+total;
    prevBtn.disabled=current===0;
    nextBtn.disabled=current===total-1;
  }
  prevBtn.onclick=()=>go(current-1);
  nextBtn.onclick=()=>go(current+1);
  document.addEventListener('keydown',e=>{
    if(e.key==='ArrowRight'||e.key===' ')go(current+1);
    if(e.key==='ArrowLeft')go(current-1);
    if(e.key==='Home')go(0);
    if(e.key==='End')go(total-1);
    if(e.key==='f'||e.key==='F'){
      const d=document.fullscreenElement;
      document[d?'exitFullscreen':'requestFullscreen']();
    }
  });
  document.addEventListener('wheel',e=>{
    const now=Date.now();
    if(now-debounce.last<WHEEL_DEBOUNCE)return;
    debounce.last=now;
    go(current+(e.deltaY>0?1:-1));
  },{passive:true});
  document.addEventListener('touchstart',e=>{debounce.ty=e.touches[0].clientY},{passive:true});
  document.addEventListener('touchend',e=>{
    const dy=debounce.ty-e.changedTouches[0].clientY;
    if(Math.abs(dy)>30)go(current+(dy>0?1:-1));
  },{passive:true});
  go(0);
})();
</script>
</body>
</html>