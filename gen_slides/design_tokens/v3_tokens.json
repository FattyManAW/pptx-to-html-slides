{
  "name": "润思IMPACTS v3.1 — Christina Canonical + Teal System",
  "version": "3.1",
  "colors": {
    "ink50": "#f8fafc",
    "ink100": "#f1f5f9",
    "ink200": "#e2e8f0",
    "ink300": "#cbd5e1",
    "ink400": "#94a3b8",
    "ink500": "#64748b",
    "ink600": "#475569",
    "ink700": "#334155",
    "ink800": "#1e293b",
    "ink900": "#0f172a",
    "ink950": "#06080d",
    "accent": "#14b8a6",
    "accentMid": "#2dd4bf",
    "surface": "rgba(255,255,255,.04)",
    "surfaceH": "rgba(255,255,255,.07)",
    "border": "rgba(255,255,255,.08)",
    "borderA": "rgba(20,184,166,.12)",
    "c-bg": "#050810",
    "c-bg2": "#0a1018",
    "c-bg3": "#0f1620",
    "c-surface": "rgba(255,255,255,.04)",
    "c-surface2": "rgba(255,255,255,.07)",
    "c-glass": "rgba(10,16,24,.65)",
    "c-border": "rgba(255,255,255,.08)",
    "c-teal": "#14b8a6",
    "c-teal-dim": "rgba(20,184,166,.12)",
    "c-teal-glow": "rgba(20,184,166,.25)",
    "c-teal-hot": "#2dd4bf",
    "c-t1": "#f0f4f8",
    "c-t2": "#94a3b8",
    "c-t3": "#64748b",
    "c-t4": "#3b5068",
    "c-error": "#ef4444",
    "c-success": "#22c55e",
    "c-warning": "#f59e0b",
    "c-info": "#3b82f6"
  },
  "typography": {
    "display": {
      "family": "'Playfair Display',serif",
      "weights": "700;800;900",
      "use": "cover-title,section-title"
    },
    "heading": {
      "family": "'Playfair Display','Noto Serif SC',serif",
      "weights": "600;700",
      "use": "slide-title,item-card h4"
    },
    "body": {
      "family": "'Inter','Noto Sans SC',sans-serif",
      "weights": "300;400;500;600;700",
      "use": "slide-body,slide-sub"
    },
    "mono": {
      "family": "monospace",
      "weights": "400;500",
      "use": "code"
    }
  },
  "timing": {
    "fast": "150ms",
    "mid": "300ms",
    "slow": "400ms",
    "stagger": [
      0,
      80,
      160,
      240,
      320
    ],
    "ease": "cubic-bezier(0.4, 0, 0.2, 1)",
    "wheelDebounce": 120
  },
  "spacing": {
    "s1": "0.5rem",
    "s2": "1rem",
    "s3": "1.5rem",
    "s4": "2rem",
    "s5": "2.5rem",
    "s6": "3rem",
    "s7": "4rem",
    "s8": "5rem",
    "s9": "6rem",
    "s10": "8rem"
  },
  "layout": {
    "maxWidth": "1100px",
    "slidePadding": "2rem",
    "sectionBreakBg": "#050810",
    "sectionNumSize": "6rem",
    "glassBlur": "blur(24px)",
    "shadow": "0 8px 40px rgba(0,0,0,.35)",
    "breakpoints": {
      "tablet": 1024,
      "mobile": 768,
      "small": 480
    },
    "blur-card": "blur(10px)",
    "blur-sheet": "blur(20px)",
    "blur-modal": "blur(30px)",
    "blur-nav": "blur(20px)"
  },
  "fonts": {
    "google": "Inter:wght@300;400;500;600;700|Playfair+Display:wght@600;700;800;900|Noto+Sans+SC:wght@300;400;500;600;700",
    "preconnect": [
      "https://fonts.googleapis.com",
      "https://fonts.gstatic.com"
    ]
  },
  "rules": {
    "noBase64": true,
    "noFlyInBounceRotate": true,
    "maxMessageBlocksPerSlide": 3,
    "minLineHeight": 1.65,
    "minFontWeights": 3,
    "requireNavModes": [
      "keyboard",
      "wheel",
      "touch"
    ],
    "requireFullscreen": true,
    "buttonStates": [
      "default",
      "hover",
      "pressed",
      "selected",
      "disabled"
    ],
    "cardModes": [
      "elevated",
      "filled",
      "outlined"
    ],
    "focusRing": "2px solid var(--c-teal), outline-offset: 2px",
    "springIn": "60% overshoot 1.01 scale, 80% settle .995"
  }
}